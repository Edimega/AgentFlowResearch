# Application
NODE_ENV=development
APP_ENV=local
APP_NAME=AgentFlow Research
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
WORKER_CONCURRENCY=3
LOG_LEVEL=info
AGENTFLOW_EXECUTION_MODE=inline

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=agentflow_session
SESSION_TTL_SECONDS=604800

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentflow
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow_dev_password
DATABASE_URL=postgresql://agentflow:agentflow_dev_password@localhost:5432/agentflow

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=agentflow
WORKFLOW_QUEUE_NAME=workflow-runs

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_UPLOADS=agentflow-uploads
S3_BUCKET_REPORTS=agentflow-reports
S3_ACCESS_KEY_ID=agentflow
S3_SECRET_ACCESS_KEY=agentflow_dev_password
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=agentflow
MINIO_ROOT_PASSWORD=agentflow_dev_password

# Model provider
LLM_PROVIDER=openrouter
NEXT_PUBLIC_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AgentFlow Research
OPENROUTER_AGENTS=writer
LLM_REQUEST_TIMEOUT_MS=10000
LLM_MAX_RETRIES=2
WEB_FETCH_TIMEOUT_MS=8000

# Tool governance
TOOL_CALL_TIMEOUT_MS=30000
TOOL_MAX_RETRIES=2
TOOL_ALLOW_WEB_SEARCH=true
TOOL_ALLOW_URL_READ=true
TOOL_ALLOW_FILE_READ=true
TOOL_ALLOW_REPORT_EXPORT=true
TOOL_ALLOW_KNOWLEDGE_BASE=false

# Security
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
MAX_WORKFLOW_INPUT_CHARS=12000
MAX_SOURCE_BYTES=5000000
PROMPT_INJECTION_DETECTION_ENABLED=true
EXTERNAL_CONTENT_QUARANTINE_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# Observability
OTEL_SERVICE_NAME=agentflow-research
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Evaluation
EVAL_DATASET_PATH=docs/evaluations.md
EVAL_RUN_OUTPUT_DIR=.agentflow/eval-runs
EVAL_MAX_CONCURRENCY=2
EVAL_FIXED_SEED=20260511
